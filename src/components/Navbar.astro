---
const navLinks = [
  { href: '/',          label: 'Home' },
  { href: '/services',  label: 'Menu & Services' },
  { href: '/locations', label: 'Locations' },
  { href: '/about',     label: 'About Us' },
  { href: '/contact',   label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm shadow-sm">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-9 h-9 bg-brand-red rounded-full flex items-center justify-center shadow">
          <span class="text-white font-display font-black text-sm leading-none">PB</span>
        </div>
        <div class="leading-tight">
          <div class="font-display font-black text-brand-green text-base leading-none">Playa Bowls</div>
          <div class="text-brand-coral text-xs font-semibold tracking-wide leading-none mt-0.5">Nashville, TN</div>
        </div>
      </a>

      <!-- Desktop Links -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`px-4 py-2 rounded-full text-sm font-semibold transition-all duration-200 ${
              currentPath === link.href
                ? 'bg-brand-dark text-white shadow'
                : 'text-brand-dark hover:bg-gray-100'
            }`}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Order CTA -->
      <a href="/contact" class="hidden md:inline-flex items-center gap-2 bg-brand-red hover:bg-red-700 text-white font-semibold text-sm px-5 py-2.5 rounded-full shadow transition-all duration-200 hover:shadow-md">
        Order Now
      </a>

      <!-- Mobile menu toggle -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-brand-dark hover:bg-gray-100 transition"
        aria-label="Open menu"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>

    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-white border-t border-gray-100 px-4 pb-4 pt-2">
    {navLinks.map(link => (
      <a
        href={link.href}
        class={`block px-4 py-3 rounded-xl text-sm font-semibold mb-1 transition ${
          currentPath === link.href
            ? 'bg-brand-green text-white'
            : 'text-brand-dark hover:bg-brand-green/10'
        }`}
      >
        {link.label}
      </a>
    ))}
    <a href="/contact" class="block mt-3 text-center bg-brand-coral text-white font-semibold text-sm px-5 py-3 rounded-full shadow">
      Order Now
    </a>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
