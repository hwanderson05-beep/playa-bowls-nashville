      { name: '8th Ave', desc: 'Playa Açaí topped with blueberry flax granola, banana & honey' },
      { name: 'Pura Vida', desc: 'Playa Açaí topped with blueberry flax granola, strawberry, blueberry & honey' },
      { name: 'Tropical', desc: 'Playa Açaí topped with blueberry flax granola, pineapple, banana, coconut flakes & honey' },
      { name: 'Nutella Bowl', desc: 'Playa Açaí topped with blueberry flax granola, strawberry, banana, coconut flakes & Nutella®' },
