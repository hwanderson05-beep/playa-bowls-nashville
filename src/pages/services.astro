    desc: 'Warm oatmeal base bowls',
    color: 'bg-stone-50',
    border: 'border-stone-200',
    dot: 'bg-stone-400',
    items: [
      { name: '#1 Nutella Bowl', desc: 'Strawberry, banana, coconut flakes, Nutella®' },
      { name: '#2 Blueberry, Strawberry & Almonds', desc: 'Blueberry, strawberry, sliced almonds' },
      { name: '#3 Power Bowl', desc: 'Banana, peanut butter, chocolate protein' },
      { name: '#4 Maple & Brown Sugar', desc: 'Maple & brown sugar' },
      { name: '#5 Banana, Cinnamon, Figs & Walnuts', desc: 'Banana, walnut, cinnamon, fig' },
    ],
  },
