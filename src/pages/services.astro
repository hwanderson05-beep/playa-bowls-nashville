];

const coldPressedJuices = [
  { name: 'Mermaid Fuel', desc: 'Kale, pineapple, apple, mint' },
  { name: 'Green Room', desc: 'Kale, apple, cucumber, mint, lemon' },
  { name: 'Ground Swell', desc: 'Kale, apple, spinach' },
  { name: 'Ding Repair', desc: 'Cucumber, carrot, apple, beet, spinach' },
  { name: 'Endless Summer', desc: 'Carrot, ginger' },
  { name: 'Beach Break', desc: 'Pineapple, carrot, ginger, lemon' },
  { name: 'Dawn Patrol', desc: 'Orange, carrot, apple' },
];

const shots = [
  { name: 'Elderberry Shot', desc: 'Apple, organic lemon, elderberry & cayenne pepper — boosts immunity & reduces inflammation' },
  { name: 'Ginger Bomb', desc: 'Orange, ginger, lemon, himalayan salt & oregano extract — improves digestion & boosts immunity' },
  { name: 'Blue Mermaid Wave', desc: 'Filtered water, organic lemon, simple syrup & blue spirulina — rich in antioxidants' },
  { name: 'Wellness Warrior', desc: 'Apple, carrot, lemon, ginger, beet, turmeric & cayenne — boosts your immune system' },
  { name: 'Green Barrel', desc: 'Pineapple, apple, chard, celery, kale, ginger, spirulina & wheatgrass — eliminates toxins' },
  { name: 'Orange Surf Quencher', desc: '100% all natural fresh oranges — good source of vitamin C' },
  { name: 'Daylight Detox', desc: 'Filtered water, organic lemon, dragon fruit puree, ginger, fo-ti root, cayenne & himalayan salt — promotes a healthy gut' },
];

const coldBrews = [
  { name: 'Playola Cold Brew', desc: 'Chicory coffee concentrate (New Orleans Style)' },
  { name: 'Sweet Cream Cold Brew', desc: 'Chicory coffee concentrate (New Orleans style) with sweet cream creamer & oat milk' },
];

const proteinWave = [
  { name: 'Protein Power Açaí Bowl', desc: 'Playa Açaí with chocolate protein topped with blueberry flax granola, banana & peanut butter', type: 'bowl' },
  { name: 'Protein Tropical Açaí Bowl', desc: 'Playa Açaí with chocolate protein topped with blueberry flax granola, pineapple, banana, coconut flakes & honey', type: 'bowl' },
  { name: 'Tidal Wave Smoothie', desc: 'Playa Coconut® blend, banana, pineapple, vanilla protein, blue spirulina, coconut milk & Cocowhip®', type: 'smoothie' },
  { name: 'Wellness Wave Smoothie', desc: 'Kale, pineapple, banana, vanilla protein, coconut milk & Cocowhip®', type: 'smoothie' },
  { name: 'Rise & Shine Smoothie', desc: 'Banana, blueberry, vanilla protein, peanut butter, blueberry flax granola & coconut milk', type: 'smoothie' },
];

const matchaMania = [
  { name: 'Coco Madness Bowl', desc: 'Half Matcha Base (Playa Coconut® Base, banana, matcha & coconut milk), Half Playa Coconut® Base topped with blueberry flax granola, strawberry, mango & coco whip', type: 'bowl' },
  { name: 'Strawberry Madness Bowl', desc: 'Half Matcha Base, Half Stupid Cupid Base (strawberry, banana & coconut milk) topped with blueberry flax granola, strawberry, banana, cacao nibs & Nutella®', type: 'bowl' },
  { name: 'Matcha Mango Smoothie', desc: 'Playa Coconut® Base, banana, matcha & coconut milk layered with Playa Mango Base', type: 'smoothie' },
  { name: 'Matcha Berry Smoothie', desc: 'Playa Coconut® Base, banana, matcha & coconut milk layered with Stupid Cupid Base (strawberry, banana & coconut milk)', type: 'smoothie' },
];
---

<Layout
  title="Menu — Açaí Bowls, Pitaya Bowls & Smoothies Nashville"
  description="Explore the full Playa Bowls Nashville menu. Açaí bowls, pitaya (dragon fruit) bowls, mango bowls, coconut bowls, smoothies, cold-pressed juices, and more. Downtown Nashville."
  keywords="açaí bowl menu Nashville, pitaya bowl Nashville, dragon fruit bowl Nashville, mango bowl Nashville, smoothie Nashville TN, cold pressed juice Nashville, Playa Bowls menu Nashville"
  canonical="https://playa-bowls-nashville.vercel.app/services"
>
  <Navbar />

  <!-- Hero -->
  <section class="bg-brand-dark py-16 text-center relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 0, transparent 50%); background-size: 20px 20px;"></div>
    <div class="relative max-w-3xl mx-auto px-4">
      <p class="text-brand-yellow font-semibold text-sm uppercase tracking-widest mb-3">Nashville, TN</p>
      <h1 class="font-display font-black text-white text-5xl md:text-6xl mb-4">Our Menu</h1>
      <p class="text-gray-400 text-lg max-w-xl mx-auto">
        Using the freshest, highest quality ingredients, we serve healthy, delicious açaí, pitaya, coconut bowls and smoothies with sustainability and community in mind.
      </p>
      <a href="/locations" class="inline-block mt-8 bg-brand-red hover:bg-red-700 text-white font-bold px-8 py-3 rounded-full transition">
        Order Now
      </a>
    </div>
  </section>

  <div class="bg-brand-cream">

    <!-- ── MATCHA MANIA ── -->
    <section class="py-14 border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="bg-green-600 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">New</span>
          <h2 class="font-display font-black text-brand-dark text-3xl">Matcha Mania 🍵</h2>
        </div>
        <p class="text-gray-500 text-sm mb-8">Earthy, vibrant, and naturally energizing — matcha brings a balanced boost to your day.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {matchaMania.map(item => (
            <div class="bg-white rounded-2xl p-5 border border-green-100 shadow-sm">
              <div class="flex items-start justify-between gap-2 mb-1.5">
                <h3 class="font-display font-bold text-brand-dark text-base">{item.name}</h3>
                <span class="shrink-0 text-xs bg-green-100 text-green-700 font-semibold px-2 py-0.5 rounded-full capitalize">{item.type}</span>
              </div>
              <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── PROTEIN WAVE ── -->
    <section class="py-14 border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">New</span>
          <h2 class="font-display font-black text-brand-dark text-3xl">Protein Wave 💪</h2>
        </div>
        <p class="text-gray-500 text-sm mb-8">A whole new wave of bowls and smoothies packed with protein — same fresh ingredients you love.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {proteinWave.map(item => (
            <div class="bg-white rounded-2xl p-5 border border-blue-100 shadow-sm">
              <div class="flex items-start justify-between gap-2 mb-1.5">
                <h3 class="font-display font-bold text-brand-dark text-base">{item.name}</h3>
                <span class="shrink-0 text-xs bg-blue-100 text-blue-700 font-semibold px-2 py-0.5 rounded-full capitalize">{item.type}</span>
              </div>
              <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── BOWLS ── -->
    <section class="py-14 border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-display font-black text-brand-dark text-3xl mb-2">Bowls 🥣</h2>
        <p class="text-gray-500 text-sm mb-10">Using predominantly plant-based ingredients, our bowls are stacked with the nourishment you need and the flavors you crave. Browse by base below.</p>

        <div class="space-y-8">
          {bowlsByBase.map(base => (
            <div class={`rounded-2xl border ${base.border} overflow-hidden`}>
              <div class={`${base.color} px-6 py-4 flex items-center gap-3`}>
                <span class="text-2xl">{base.emoji}</span>
                <div>
                  <h3 class="font-display font-bold text-brand-dark text-lg leading-none">{base.base}</h3>
                  <p class="text-gray-500 text-xs mt-0.5">{base.desc}</p>
                </div>
                <span class="ml-auto text-xs font-bold text-gray-400">{base.items.length} bowls</span>
              </div>
              <div class="bg-white divide-y divide-gray-100">
                {base.items.map(item => (
                  <div class="px-6 py-4 flex items-start gap-3">
                    <div class={`w-2 h-2 rounded-full ${base.dot} mt-1.5 shrink-0`}></div>
                    <div>
                      <span class="font-semibold text-brand-dark text-sm">{item.name}</span>
                      <p class="text-gray-500 text-sm leading-relaxed mt-0.5">{item.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}

          <!-- Special Bowls -->
          <div class="rounded-2xl border border-red-200 overflow-hidden">
            <div class="bg-red-50 px-6 py-4 flex items-center gap-3">
              <span class="text-2xl">⭐</span>
              <div>
                <h3 class="font-display font-bold text-brand-dark text-lg leading-none">Special Bowls</h3>
                <p class="text-gray-500 text-xs mt-0.5">Fan favorites with unique blends</p>
              </div>
            </div>
            <div class="bg-white divide-y divide-gray-100">
              {specialBowls.map(item => (
                <div class="px-6 py-4 flex items-start gap-3">
                  <div class="w-2 h-2 rounded-full bg-red-400 mt-1.5 shrink-0"></div>
                  <div>
                    <span class="font-semibold text-brand-dark text-sm">{item.name}</span>
                    <p class="text-gray-500 text-sm leading-relaxed mt-0.5">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── SMOOTHIES ── -->
    <section class="py-14 border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-display font-black text-brand-dark text-3xl mb-2">Smoothies 🥤</h2>
        <p class="text-gray-500 text-sm mb-8">Available in 16oz or 20oz.</p>
        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm">
          <div class="grid grid-cols-1 sm:grid-cols-2">
            {smoothies.map((item, i) => (
              <div class={`px-6 py-4 border-b border-gray-100 ${i % 2 !== 0 ? 'sm:border-l' : ''}`}>
                <div class="font-semibold text-brand-dark text-sm">{item.name}</div>
                <p class="text-gray-500 text-sm mt-0.5 leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ── COLD PRESSED JUICES ── -->
    <section class="py-14 border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-display font-black text-brand-dark text-3xl mb-2">Cold Pressed Juices 🍏</h2>
        <p class="text-gray-500 text-sm mb-8">Available in 12oz, 16oz, or 20oz. Tastes best after a surf sesh!</p>
        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm">
          <div class="grid grid-cols-1 sm:grid-cols-2">
            {coldPressedJuices.map((item, i) => (
              <div class={`px-6 py-4 border-b border-gray-100 ${i % 2 !== 0 ? 'sm:border-l' : ''}`}>
                <div class="font-semibold text-brand-dark text-sm">{item.name}</div>
                <p class="text-gray-500 text-sm mt-0.5 leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Shots -->
        <h3 class="font-display font-bold text-brand-dark text-xl mt-10 mb-4">Wellness Shots ⚡</h3>
        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm">
          {shots.map(item => (
            <div class="px-6 py-4 border-b border-gray-100 last:border-0">
              <div class="font-semibold text-brand-dark text-sm">{item.name}</div>
              <p class="text-gray-500 text-sm mt-0.5 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── COLD BREW ── -->
    <section class="py-14">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-display font-black text-brand-dark text-3xl mb-2">Cold Brew ☕</h2>
        <p class="text-gray-500 text-sm mb-8">Our specialty Cold Brew line, sure to fuel your day!</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {coldBrews.map(item => (
            <div class="bg-white rounded-2xl p-6 border border-gray-200 shadow-sm">
              <div class="font-display font-bold text-brand-dark text-lg mb-1">{item.name}</div>
              <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

  </div>

  <!-- Nutrition note -->
  <section class="bg-brand-dark py-10 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <p class="text-gray-400 text-sm">
        Menu items may vary by location. For nutrition facts, allergen info, and customization options, ask our team in-store.
        Full nutrition information available at <a href="https://playabowls.com" class="text-brand-yellow hover:underline" target="_blank" rel="noopener noreferrer">playabowls.com</a>.
      </p>
    </div>
  </section>

  <Footer />
</Layout>
