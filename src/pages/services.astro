const specialBowls = [
  { name: 'Booster Bowl', desc: 'Booster blend (banana, peanut butter, vanilla protein, flax oil, spirulina & cashew milk) topped with blueberry flax granola, banana, chia seeds & peanut butter' },
  { name: 'Stupid Cupid Bowl', desc: 'Stupid Cupid blend (strawberry, banana & coconut milk) topped with blueberry flax granola, strawberry, cacao nibs, coconut flakes, Nutella® & white chocolate' },
];

const smoothies = [
  { name: 'Pink Pitaya', desc: 'Playa Pitaya, coconut milk' },
  { name: 'Strawberry Banana', desc: 'Strawberry, banana, coconut milk' },
  { name: 'Matcha', desc: 'Matcha green tea, banana, pineapple, coconut milk' },
  { name: 'Orange Power', desc: 'Orange, vanilla protein, pineapple, coconut milk' },
  { name: 'Green Smoothie', desc: 'Kale, pineapple, banana, coconut milk' },
  { name: 'Kowabunga', desc: 'Banana, strawberry, blueberry, coconut milk' },
  { name: 'Dang', desc: 'Banana, wheat grass powder, peanut butter, cinnamon, almond milk' },
  { name: 'Dolce', desc: 'Banana, chocolate protein, peanut butter, coconut milk' },
  { name: 'Aloha', desc: 'Banana, mango, pineapple, coconut milk' },
  { name: 'Booster', desc: 'Banana, vanilla protein, flax oil, spirulina, peanut butter, cashew milk' },
  { name: 'Acai Energy', desc: 'Playa Açaí, strawberry, banana, coconut milk' },
  { name: 'Coconut New Orleans', desc: 'Banana, coconut base, chicory coffee concentrate, cacao nibs & oat milk' },
