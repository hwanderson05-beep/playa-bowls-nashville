    emoji: '🥬',
    desc: 'Kale, banana, pineapple & coconut milk',
    color: 'bg-green-50',
    border: 'border-green-200',
    dot: 'bg-green-400',
    items: [
      { name: 'Ocean Ave', desc: 'Green blend topped with blueberry flax granola, banana & honey' },
      { name: 'Pacific', desc: 'Green blend topped with blueberry flax granola, banana, strawberry, sliced almonds, chia seeds & honey' },
      { name: 'Hemp', desc: 'Green blend topped with blueberry flax granola, banana, blueberry, hemp seeds & agave' },
      { name: 'Lola', desc: 'Green blend topped with blueberry flax granola, pineapple, mango, coconut flakes & honey' },
      { name: 'Green Power Bowl', desc: 'Green blend with vanilla protein topped with blueberry flax granola, banana & almond butter' },
    ],
  },
  {
    base: 'Banana',
    emoji: '🍌',
    desc: 'Banana, honey & almond milk base',
    color: 'bg-amber-50',
    border: 'border-amber-200',
    dot: 'bg-amber-400',
    items: [
      { name: 'Nica', desc: 'Banana blend topped with blueberry flax granola, banana, strawberry, walnuts, cacao nibs & peanut butter' },
