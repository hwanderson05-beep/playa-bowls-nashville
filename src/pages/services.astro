      { name: 'Coco Craze', desc: 'Playa Coconut blend topped with blueberry flax granola, banana, mango, pineapple, coconut flakes & honey' },
      { name: 'Coconut Power', desc: 'Playa Coconut blend with vanilla protein topped with blueberry flax granola, banana, coconut flakes & almond butter' },
      { name: 'Nutelloco', desc: 'Playa Coconut blend topped with blueberry flax granola, banana, strawberry, coconut flakes, cacao nibs & Nutella®' },
    ],
  },
  {
