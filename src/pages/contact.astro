---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const SITE_URL = "https://playa-bowls-nashville.vercel.app";

const contactSchema = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "@id": `${SITE_URL}/contact#webpage`,
    "url": `${SITE_URL}/contact`,
    "name": "Contact Playa Bowls Nashville — Order, Catering & Inquiries",
    "description": "Contact Playa Bowls Nashville for orders, catering, event inquiries, or general questions. Located at 246 Rep John Lewis Way N, Nashville TN. Open Mon–Fri 7 AM.",
    "isPartOf": { "@id": `${SITE_URL}/#website` },
    "about": { "@id": `${SITE_URL}/#restaurant` },
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
        { "@type": "ListItem", "position": 2, "name": "Contact", "item": `${SITE_URL}/contact` }
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": `${SITE_URL}/contact#catering`,
    "name": "Smoothie Bowl Catering Nashville",
    "serviceType": "Food Catering",
    "description": "Playa Bowls Nashville offers catering for corporate events, office lunches, weddings, and private parties in Nashville, TN. Fresh açaí bowls, pitaya bowls, and smoothies made to order.",
    "areaServed": {
      "@type": "City",
      "name": "Nashville",
      "addressRegion": "TN"
    },
    "provider": { "@id": `${SITE_URL}/#restaurant` },
    "offers": {
      "@type": "Offer",
      "name": "Catering Inquiry",
      "url": `${SITE_URL}/contact`,
      "description": "Request a catering quote for your event. Corporate lunches, office catering, weddings, and more."
    }
  }
];
---

<Layout
  title="Contact — Order & Get in Touch"
  description="Contact Playa Bowls Nashville at 246 Rep John Lewis Way N, Nashville TN. Order online, ask about catering, or just say hi. Open Mon–Fri 7 AM."
  keywords="Playa Bowls Nashville contact, order açaí bowl Nashville, catering Nashville healthy food, contact Playa Bowls downtown Nashville, smoothie bowl catering Nashville"
  canonical="https://playa-bowls-nashville.vercel.app/contact"
  pageSchema={contactSchema}
>
  <Navbar />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-brand-yellow to-orange-300 py-20 text-center relative overflow-hidden">
    <div class="absolute -top-10 -left-10 w-64 h-64 bg-white/20 rounded-full blur-3xl pointer-events-none"></div>
    <div class="relative max-w-3xl mx-auto px-4">
      <span class="text-yellow-800 font-semibold text-sm uppercase tracking-widest">We'd love to hear from you</span>
      <h1 class="font-display font-black text-brand-dark text-5xl md:text-6xl mt-3 mb-4">Say Hello</h1>
      <p class="text-yellow-900 text-lg">Have a question, catering request, or just want to chat? We're all ears.</p>
    </div>
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 50" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 50L1440 50L1440 20C1200 45 960 50 720 42C480 35 240 10 0 20L0 50Z" fill="#FFF8F0"/>
      </svg>
    </div>
  </section>

  <!-- Contact section -->
  <section class="py-20 bg-brand-cream">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

        <!-- Info -->
        <div>
          <h2 class="font-display font-black text-brand-dark text-3xl mb-2">Contact Info</h2>
          <p class="text-gray-500 mb-8 leading-relaxed">Stop in, call, or drop us a message and we'll get back to you within one business day.</p>

          <div class="space-y-5">
            <div class="flex gap-4 items-start bg-white rounded-2xl p-5 shadow-sm border border-orange-50">
              <div class="w-11 h-11 bg-brand-green/10 text-brand-green rounded-xl flex items-center justify-center text-xl shrink-0">📍</div>
              <div>
                <div class="font-semibold text-brand-dark text-sm mb-0.5">Address</div>
                <div class="text-gray-500 text-sm">246 Rep John Lewis Way N<br/>Nashville, TN 37219</div>
              </div>
            </div>

            <div class="flex gap-4 items-start bg-white rounded-2xl p-5 shadow-sm border border-orange-50">
              <div class="w-11 h-11 bg-brand-coral/10 text-brand-coral rounded-xl flex items-center justify-center text-xl shrink-0">📞</div>
              <div>
                <div class="font-semibold text-brand-dark text-sm mb-0.5">Phone</div>
                <a href="tel:+16155550100" class="text-gray-500 text-sm hover:text-brand-coral transition">(615) 555-0100</a>
              </div>
            </div>

            <div class="flex gap-4 items-start bg-white rounded-2xl p-5 shadow-sm border border-orange-50">
              <div class="w-11 h-11 bg-brand-yellow/30 text-yellow-700 rounded-xl flex items-center justify-center text-xl shrink-0">✉️</div>
              <div>
                <div class="font-semibold text-brand-dark text-sm mb-0.5">Email</div>
                <a href="mailto:hello@playabowlstn.com" class="text-gray-500 text-sm hover:text-brand-coral transition">hello@playabowlstn.com</a>
              </div>
            </div>

            <div class="flex gap-4 items-start bg-white rounded-2xl p-5 shadow-sm border border-orange-50">
              <div class="w-11 h-11 bg-purple-100 text-purple-600 rounded-xl flex items-center justify-center text-xl shrink-0">🕐</div>
              <div>
                <div class="font-semibold text-brand-dark text-sm mb-1">Hours</div>
                <div class="text-gray-500 text-sm space-y-1">
                  <div>Mon–Fri: <span class="font-medium text-brand-dark">7:00 AM – 7:00 PM</span></div>
                  <div>Sat–Sun: <span class="font-medium text-brand-dark">8:00 AM – 6:00 PM</span></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Social -->
          <div class="mt-8">
            <p class="text-sm font-semibold text-brand-dark mb-3">Follow us on social</p>
            <div class="flex gap-3">
              <a href="https://instagram.com/playabowlstn" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-gradient-to-br from-pink-500 to-purple-600 text-white rounded-xl flex items-center justify-center hover:scale-110 transition-transform">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              </a>
              <a href="https://facebook.com/playabowlstn" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-blue-600 text-white rounded-xl flex items-center justify-center hover:scale-110 transition-transform">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
              <a href="https://tiktok.com/@playabowlstn" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-brand-dark text-white rounded-xl flex items-center justify-center hover:scale-110 transition-transform text-sm font-bold">
                TK
              </a>
            </div>
          </div>
        </div>

        <!-- Contact form -->
        <div>
          <div class="bg-white rounded-3xl shadow-sm p-8 border border-orange-50">
            <h2 class="font-display font-black text-brand-dark text-2xl mb-1">Send a Message</h2>
            <p class="text-gray-500 text-sm mb-6">We'll respond within one business day.</p>

            <form
              name="contact"
              method="POST"
              data-netlify="true"
              action="/contact?success=true"
              class="space-y-4"
            >
              <input type="hidden" name="form-name" value="contact" />

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-xs font-semibold text-brand-dark mb-1.5 uppercase tracking-wide" for="first-name">First Name</label>
                  <input
                    type="text"
                    id="first-name"
                    name="first-name"
                    required
                    placeholder="Jane"
                    class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-brand-dark placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-green/40 focus:border-brand-green transition"
                  />
                </div>
                <div>
                  <label class="block text-xs font-semibold text-brand-dark mb-1.5 uppercase tracking-wide" for="last-name">Last Name</label>
                  <input
                    type="text"
                    id="last-name"
                    name="last-name"
                    required
                    placeholder="Smith"
                    class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-brand-dark placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-green/40 focus:border-brand-green transition"
                  />
                </div>
              </div>

              <div>
                <label class="block text-xs font-semibold text-brand-dark mb-1.5 uppercase tracking-wide" for="email">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="jane@example.com"
                  class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-brand-dark placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-green/40 focus:border-brand-green transition"
                />
              </div>

              <div>
                <label class="block text-xs font-semibold text-brand-dark mb-1.5 uppercase tracking-wide" for="subject">Subject</label>
                <select
                  id="subject"
                  name="subject"
                  class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-brand-dark focus:outline-none focus:ring-2 focus:ring-brand-green/40 focus:border-brand-green transition bg-white"
                >
                  <option value="general">General Question</option>
                  <option value="catering">Catering Inquiry</option>
                  <option value="feedback">Feedback</option>
                  <option value="partnership">Partnership / Event</option>
                  <option value="other">Other</option>
                </select>
              </div>

              <div>
                <label class="block text-xs font-semibold text-brand-dark mb-1.5 uppercase tracking-wide" for="message">Message</label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows={5}
                  placeholder="Tell us what's on your mind..."
                  class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-brand-dark placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-green/40 focus:border-brand-green transition resize-none"
                ></textarea>
              </div>

              <button
                type="submit"
                class="w-full bg-brand-green hover:bg-green-700 text-white font-bold py-4 rounded-full shadow transition-all hover:shadow-md text-base"
              >
                Send Message 🌊
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer />
</Layout>
