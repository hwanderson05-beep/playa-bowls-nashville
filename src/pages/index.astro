---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const categories = [
  { emoji: '🫐', name: 'Açaí Bowls', href: '/services#acai', color: 'bg-purple-100 hover:bg-purple-200' },
  { emoji: '🥭', name: 'Mango Bowls', href: '/services#mango', color: 'bg-orange-100 hover:bg-orange-200' },
  { emoji: '🐉', name: 'Pitaya Bowls', href: '/services#pitaya', color: 'bg-pink-100 hover:bg-pink-200' },
  { emoji: '🥥', name: 'Coconut Bowls', href: '/services#coconut', color: 'bg-yellow-100 hover:bg-yellow-200' },
  { emoji: '🥬', name: 'Green Bowls', href: '/services#green', color: 'bg-green-100 hover:bg-green-200' },
  { emoji: '🥤', name: 'Smoothies', href: '/services#smoothies', color: 'bg-sky-100 hover:bg-sky-200' },
  { emoji: '🍏', name: 'Cold Pressed', href: '/services#juices', color: 'bg-lime-100 hover:bg-lime-200' },
  { emoji: '☕', name: 'Cold Brew', href: '/services#coldbrew', color: 'bg-amber-100 hover:bg-amber-200' },
];
---

<Layout
  title="Açaí Bowls & Pitaya Bowls in Nashville, TN"
  description="Playa Bowls Nashville — Nashville's best açaí bowls, pitaya (dragon fruit) bowls, and smoothies. Open 7 AM Mon–Fri at 246 Rep John Lewis Way N, downtown Nashville."
  keywords="açaí bowl Nashville, pitaya bowl Nashville, dragon fruit bowl Nashville, acai bowl downtown Nashville, smoothie bowl Nashville TN, healthy breakfast Nashville, best açaí Nashville"
  canonical="https://playa-bowls-nashville.vercel.app"
>
  <Navbar />

  <!-- Hero -->
  <section class="bg-brand-dark min-h-[520px] flex items-center relative overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-brand-red/20 rounded-full blur-3xl pointer-events-none -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-80 h-80 bg-brand-teal/20 rounded-full blur-3xl pointer-events-none translate-y-1/2 -translate-x-1/2"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center w-full">
      <p class="text-brand-yellow font-semibold text-sm uppercase tracking-[0.2em] mb-4">Nashville, Tennessee</p>
      <h1 class="font-display font-black text-white text-5xl md:text-7xl leading-none mb-3">
        find your<br/>
        <span class="text-brand-yellow">playa bowls</span>
      </h1>
      <p class="text-gray-400 text-lg md:text-xl max-w-2xl mx-auto mt-6 mb-10 leading-relaxed">
        Playa Bowls™ is your slice of summer, anytime. Using the freshest, highest quality ingredients, we serve healthy, delicious açaí, pitaya, coconut bowls and smoothies with sustainability and community in mind.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/services" class="bg-brand-red hover:bg-red-700 text-white font-bold text-lg px-8 py-4 rounded-full shadow-lg transition-all hover:-translate-y-0.5">
          View Full Menu
        </a>
        <a href="/locations" class="bg-white/10 hover:bg-white/20 text-white font-bold text-lg px-8 py-4 rounded-full border border-white/20 transition-all">
          Find Our Location
        </a>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 40L1440 40L1440 15C1200 35 960 40 720 32C480 24 240 5 0 15L0 40Z" fill="#FAFAF8"/>
      </svg>
    </div>
  </section>

  <!-- Browse by Category -->
  <section class="py-16 bg-brand-cream">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display font-black text-brand-dark text-3xl md:text-4xl text-center mb-2">Browse Our Menu</h2>
      <p class="text-center text-gray-500 mb-10">Born on the beach and built for Music City.</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {categories.map(cat => (
          <a href={cat.href} class={`${cat.color} rounded-2xl p-5 text-center transition-all hover:scale-105 hover:shadow-sm`}>
            <div class="text-4xl mb-2">{cat.emoji}</div>
            <div class="font-display font-bold text-brand-dark text-sm">{cat.name}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Brand statement -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-brand-red font-semibold text-sm uppercase tracking-widest mb-3">Your Morning Booster</p>
          <h2 class="font-display font-black text-brand-dark text-4xl mb-5 leading-tight">
            Your Morning Booster &amp; Lunch Break Dream
          </h2>
          <p class="text-gray-500 leading-relaxed mb-4">
            We're your morning booster and your lunch break dream; your post-surf fix and perfect nightcap. Using predominantly plant-based ingredients, our bowls are stacked with the nourishment you need and the flavors you crave.
          </p>
          <p class="text-gray-500 leading-relaxed mb-8">
            We can't wait to see you again!
          </p>
          <a href="/services" class="inline-flex items-center gap-2 bg-brand-dark hover:bg-gray-800 text-white font-bold px-8 py-3 rounded-full transition-all">
            Order Now →
          </a>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-brand-red rounded-3xl p-7 text-white text-center">
            <div class="font-display font-black text-4xl mb-1">74+</div>
            <div class="text-red-200 text-sm">Menu Items</div>
          </div>
          <div class="bg-brand-teal rounded-3xl p-7 text-white text-center">
            <div class="font-display font-black text-4xl mb-1">7</div>
            <div class="text-teal-200 text-sm">Bowl Bases</div>
          </div>
          <div class="bg-brand-yellow rounded-3xl p-7 text-brand-dark text-center">
            <div class="font-display font-black text-4xl mb-1">100%</div>
            <div class="text-yellow-800 text-sm">Plant-Based Options</div>
          </div>
          <div class="bg-brand-dark rounded-3xl p-7 text-white text-center">
            <div class="font-display font-black text-4xl mb-1">1</div>
            <div class="text-gray-400 text-sm">Nashville Location</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- New arrivals callout -->
  <section class="py-16 bg-brand-cream">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display font-black text-brand-dark text-3xl md:text-4xl text-center mb-10">What's New</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="bg-green-700 rounded-3xl p-8 text-white">
          <span class="inline-block bg-white/20 text-white text-xs font-bold px-3 py-1 rounded-full mb-4">New</span>
          <h3 class="font-display font-black text-2xl mb-3">Matcha Mania 🍵</h3>
          <p class="text-green-100 text-sm leading-relaxed mb-6">
            Matcha Mania has officially arrived! Earthy, vibrant, and naturally energizing, matcha brings a balanced boost to your day. Paired with coconut, mango, strawberry, and more — this lineup blends wellness and flavor the Playa way. 💚
          </p>
          <a href="/services" class="inline-block bg-white text-green-700 font-bold text-sm px-6 py-2.5 rounded-full hover:bg-green-50 transition">Try It Now</a>
        </div>
        <div class="bg-blue-700 rounded-3xl p-8 text-white">
          <span class="inline-block bg-white/20 text-white text-xs font-bold px-3 py-1 rounded-full mb-4">New</span>
          <h3 class="font-display font-black text-2xl mb-3">Protein Wave 💪</h3>
          <p class="text-blue-100 text-sm leading-relaxed mb-6">
            Introducing a whole new wave of bowls and smoothies made with the same fresh ingredients you love, now packed with protein. Fuel your day the Playa way.
          </p>
          <a href="/services" class="inline-block bg-white text-blue-700 font-bold text-sm px-6 py-2.5 rounded-full hover:bg-blue-50 transition">Try It Now</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Neighborhood / Local SEO Section -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display font-black text-brand-dark text-3xl md:text-4xl text-center mb-4">Nashville's Pitaya & Açaí Spot</h2>
      <p class="text-center text-gray-500 max-w-2xl mx-auto mb-10">We're conveniently located downtown — an easy stop whether you're in SoBro, The Gulch, Germantown, or rolling through Broadway.</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-12">
        {[
          { area: 'Downtown / SoBro', mins: '2 min walk', emoji: '🏙️' },
          { area: 'The Gulch', mins: '5 min drive', emoji: '🌿' },
          { area: 'Germantown', mins: '8 min drive', emoji: '🏘️' },
          { area: 'East Nashville', mins: '10 min drive', emoji: '🎸' },
        ].map(n => (
          <div class="bg-brand-cream rounded-2xl p-5 text-center">
            <div class="text-3xl mb-2">{n.emoji}</div>
            <div class="font-display font-bold text-brand-dark text-sm leading-tight">{n.area}</div>
            <div class="text-gray-400 text-xs mt-1">{n.mins}</div>
          </div>
        ))}
      </div>
      <div class="bg-brand-dark rounded-3xl p-8 md:p-10 text-center">
        <h3 class="font-display font-black text-white text-2xl md:text-3xl mb-3">Open Early — Every Weekday at 7 AM</h3>
        <p class="text-gray-300 max-w-xl mx-auto mb-6">Beat the day with a dragon fruit pitaya bowl or an açaí bowl before work. We're one of the only spots in Nashville open this early with fresh, made-to-order bowls.</p>
        <a href="/services" class="inline-flex bg-brand-yellow text-brand-dark font-bold px-8 py-3 rounded-full hover:bg-yellow-300 transition-all">
          See the Full Menu →
        </a>
      </div>
    </div>
  </section>

  <!-- Hours Banner -->
  <section class="bg-brand-red py-12 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-display font-black text-white text-3xl mb-6">Visit Us Today</h2>
      <div class="inline-grid grid-cols-2 gap-x-16 gap-y-2 text-white font-semibold mb-8">
        <span class="text-right text-red-200 font-normal">Mon – Fri</span>
        <span class="text-left">7:00 AM – 7:00 PM</span>
        <span class="text-right text-red-200 font-normal">Sat – Sun</span>
        <span class="text-left">8:00 AM – 6:00 PM</span>
      </div>
      <div>
        <a href="/locations" class="bg-white text-brand-red hover:bg-red-50 font-bold px-8 py-3 rounded-full shadow transition-all">
          Get Directions
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
