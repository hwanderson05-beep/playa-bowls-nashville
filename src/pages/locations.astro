---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const SITE_URL = "https://playa-bowls-nashville.vercel.app";

const locationsSchema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${SITE_URL}/locations#webpage`,
    "url": `${SITE_URL}/locations`,
    "name": "Location & Hours — Playa Bowls Downtown Nashville",
    "description": "Find Playa Bowls Nashville at 246 Rep John Lewis Way N, Nashville, TN 37219. Open Mon–Fri 7 AM, Sat–Sun 8 AM.",
    "isPartOf": { "@id": `${SITE_URL}/#website` },
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
        { "@type": "ListItem", "position": 2, "name": "Locations", "item": `${SITE_URL}/locations` }
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "FoodEstablishment", "Restaurant"],
    "@id": `${SITE_URL}/locations#localbusiness`,
    "name": "Playa Bowls Nashville",
    "url": SITE_URL,
    "telephone": "+16155550100",
    "email": "hello@playabowlstn.com",
    "image": `${SITE_URL}/og-image.jpg`,
    "priceRange": "$$",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "246 Rep John Lewis Way N",
      "addressLocality": "Nashville",
      "addressRegion": "TN",
      "postalCode": "37219",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 36.1627,
      "longitude": -86.7816
    },
    "openingHours": ["Mo-Fr 07:00-19:00", "Sa-Su 08:00-18:00"],
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "07:00",
        "closes": "19:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Saturday","Sunday"],
        "opens": "08:00",
        "closes": "18:00"
      }
    ],
    "hasMap": "https://maps.google.com/?q=246+Rep+John+Lewis+Way+N+Nashville+TN+37219",
    "publicAccess": true,
    "smokingAllowed": false,
    "amenityFeature": [
      { "@type": "LocationFeatureSpecification", "name": "Wheelchair Accessible", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Pet-Friendly Outdoor Seating", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Nearby Parking", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Online Ordering", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Delivery", "value": true }
    ],
    "areaServed": [
      { "@type": "Neighborhood", "name": "Downtown Nashville" },
      { "@type": "Neighborhood", "name": "SoBro" },
      { "@type": "Neighborhood", "name": "The Gulch" },
      { "@type": "Neighborhood", "name": "Germantown" },
      { "@type": "Neighborhood", "name": "East Nashville" },
      { "@type": "Neighborhood", "name": "Midtown Nashville" },
      { "@type": "Neighborhood", "name": "Wedgewood-Houston" },
      { "@type": "Neighborhood", "name": "12South" }
    ],
    "nearbyPOI": [
      "Bridgestone Arena",
      "Tennessee State Capitol",
      "Ryman Auditorium",
      "Broadway Nashville",
      "Nashville Farmers Market",
      "Country Music Hall of Fame"
    ]
  }
];
---

<Layout
  title="Location & Hours — Downtown Nashville"
  description="Find Playa Bowls Nashville at 246 Rep John Lewis Way N, Nashville, TN 37219. Open Mon–Fri 7 AM, Sat–Sun 8 AM. Açaí bowls, pitaya (dragon fruit) bowls & smoothies near SoBro, The Gulch, and Germantown."
  keywords="Playa Bowls Nashville location, açaí bowl downtown Nashville, pitaya bowl Nashville address, acai bowl near me Nashville, healthy food downtown Nashville TN, bowl restaurant Nashville"
  canonical="https://playa-bowls-nashville.vercel.app/locations"
  pageSchema={locationsSchema}
>
  <Navbar />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-brand-coral to-orange-600 py-20 text-center relative overflow-hidden">
    <div class="absolute -bottom-10 -right-10 w-64 h-64 bg-white/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="relative max-w-3xl mx-auto px-4">
      <span class="text-orange-100 font-semibold text-sm uppercase tracking-widest">Nashville, TN</span>
      <h1 class="font-display font-black text-white text-5xl md:text-6xl mt-3 mb-4">Find Us</h1>
      <p class="text-orange-100 text-lg">We're in the heart of downtown Nashville — come say hi!</p>
    </div>
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 50" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 50L1440 50L1440 20C1200 45 960 50 720 42C480 35 240 10 0 20L0 50Z" fill="#FFF8F0"/>
      </svg>
    </div>
  </section>

  <!-- Location Card -->
  <section class="py-20 bg-brand-cream">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-3xl shadow-sm overflow-hidden border border-orange-100">
        <div class="grid grid-cols-1 lg:grid-cols-2">

          <!-- Map embed -->
          <div class="bg-gray-100 min-h-72 lg:min-h-full relative">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3221.7!2d-86.7816!3d36.1627!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x886466c6b8db9a0d%3A0x0!2s246+Rep+John+Lewis+Way+N%2C+Nashville%2C+TN+37219!5e0!3m2!1sen!2sus!4v1"
              width="100%"
              height="100%"
              style="min-height: 300px; border: 0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Playa Bowls Nashville map"
              class="w-full h-full"
            ></iframe>
          </div>

          <!-- Info -->
          <div class="p-8 lg:p-10 flex flex-col justify-center">
            <div class="inline-flex items-center gap-2 bg-brand-green/10 text-brand-green text-xs font-bold px-3 py-1 rounded-full mb-5 w-fit">
              📍 Downtown Nashville
            </div>

            <h2 class="font-display font-black text-brand-dark text-3xl mb-2">Playa Bowls Nashville</h2>
            <address class="not-italic text-gray-600 text-base mb-8 leading-relaxed">
              246 Rep John Lewis Way N<br/>
              Nashville, TN 37219
            </address>

            <!-- Hours -->
            <div class="bg-brand-cream rounded-2xl p-5 mb-8">
              <h3 class="font-display font-bold text-brand-dark text-base mb-3 flex items-center gap-2">
                <span>🕐</span> Hours
              </h3>
              <div class="space-y-2 text-sm">
                <div class="flex justify-between">
                  <span class="text-gray-500">Monday – Friday</span>
                  <span class="font-semibold text-brand-dark">7:00 AM – 7:00 PM</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-gray-500">Saturday – Sunday</span>
                  <span class="font-semibold text-brand-dark">8:00 AM – 6:00 PM</span>
                </div>
              </div>
            </div>

            <!-- Actions -->
            <div class="flex flex-col sm:flex-row gap-3">
              <a
                href="https://maps.google.com/?q=246+Rep+John+Lewis+Way+N+Nashville+TN+37219"
                target="_blank"
                rel="noopener noreferrer"
                class="flex-1 bg-brand-green hover:bg-green-700 text-white font-bold text-center px-6 py-3 rounded-full shadow transition-all hover:shadow-md"
              >
                Get Directions
              </a>
              <a
                href="tel:+16155550100"
                class="flex-1 bg-brand-coral hover:bg-orange-500 text-white font-bold text-center px-6 py-3 rounded-full shadow transition-all hover:shadow-md"
              >
                Call Us
              </a>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Parking / Accessibility -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display font-black text-brand-dark text-3xl md:text-4xl text-center mb-10">Good to Know</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {[
          { emoji: '🅿️', title: 'Parking', desc: 'Street parking available nearby. Public garage within 2 blocks on 3rd Ave N.' },
          { emoji: '♿', title: 'Accessibility', desc: 'Fully wheelchair accessible entrance and restrooms.' },
          { emoji: '🐾', title: 'Pet-Friendly', desc: 'Outdoor seating is dog-friendly. Bring your pup!' },
        ].map(item => (
          <div class="bg-brand-cream rounded-2xl p-6 text-center">
            <div class="text-4xl mb-3">{item.emoji}</div>
            <h3 class="font-display font-bold text-brand-dark text-lg mb-2">{item.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Neighborhood Proximity -->
  <section class="py-16 bg-brand-cream">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display font-black text-brand-dark text-3xl text-center mb-3">Close to Every Nashville Neighborhood</h2>
      <p class="text-center text-gray-500 mb-10 max-w-2xl mx-auto">Whether you work downtown, live in SoBro, or you're visiting Music City — we're right in the middle of it all.</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {[
          { area: 'Downtown / SoBro', travel: '2 min walk', emoji: '🏙️' },
          { area: 'The Gulch', travel: '5 min drive', emoji: '🌿' },
          { area: 'Germantown', travel: '8 min drive', emoji: '🏘️' },
          { area: 'East Nashville', travel: '10 min drive', emoji: '🎸' },
          { area: 'Midtown', travel: '7 min drive', emoji: '🎶' },
          { area: 'WeHo / 12South', travel: '10 min drive', emoji: '☀️' },
          { area: 'Wedgewood-Houston', travel: '8 min drive', emoji: '🎨' },
          { area: 'Brentwood / Cool Springs', travel: '20 min drive', emoji: '🌳' },
        ].map(n => (
          <div class="bg-white rounded-2xl p-5 text-center shadow-sm">
            <div class="text-3xl mb-2">{n.emoji}</div>
            <div class="font-display font-bold text-brand-dark text-sm leading-tight">{n.area}</div>
            <div class="text-gray-400 text-xs mt-1">{n.travel}</div>
          </div>
        ))}
      </div>
      <div class="mt-10 bg-brand-dark rounded-3xl p-8 text-center">
        <p class="text-white font-display font-black text-xl mb-2">Searching for "açaí bowl near me" or "pitaya bowl Nashville"?</p>
        <p class="text-gray-400 text-sm max-w-lg mx-auto">You found us. Playa Bowls Nashville is downtown Nashville's go-to for dragon fruit pitaya bowls, açaí bowls, mango bowls, fresh smoothies, and cold-pressed juices.</p>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
